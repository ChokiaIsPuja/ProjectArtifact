<?php
include __DIR__ . '/conn.php';
session_start();

if ($_SERVER['REQUEST_METHOD'] === 'POST' && !empty($_POST)) {
    $action = isset($_POST['action']) ? $_POST['action'] : (isset($_POST['aksi']) ? $_POST['aksi'] : '');

    if ($action === 'add' || $action === 'tambah') {
        $name = isset($_POST['name']) ? trim($_POST['name']) : '';
        $classId = isset($_POST['class_id']) ? intval($_POST['class_id']) : 0;
        $id_user = isset($_POST['id_user']) ? intval($_POST['id_user']) : (isset($_SESSION['id_user']) ? intval($_SESSION['id_user']) : 0);

        if ($name === '' || $classId <= 0 || $id_user <= 0) {
            header('Location: index.php?error=missing');
            exit;
        }

        $name = mysqli_real_escape_string($conn, $name);
        $lvl = 1; // default level
        $exp = 0; // default experience
        $gold = 0; // default gold
        $created_for = $id_user; // associate character with logged-in user
        $created_at = date('Y-m-d H:i:s');

        $query = "INSERT INTO player (name, class_id, level, exp, gold, id_user, created_at) VALUES ('$name', $classId, $lvl, $exp, $gold, $created_for, '$created_at')";
        if (!mysqli_query($conn, $query)) {
            header('Location: index.php?error=save');
            exit;
        }

        header('Location: index.php?saved=1');
        exit;
    }

    if ($action === 'edit') {
        $id = isset($_POST['id']) ? intval($_POST['id']) : 0;
        $name = isset($_POST['name']) ? trim($_POST['name']) : '';
        $classId = isset($_POST['class_id']) ? intval($_POST['class_id']) : 0;

        if ($id <= 0 || $name === '' || $classId <= 0) {
            header('Location: index.php?error=missing');
            exit;
        }

        $name = mysqli_real_escape_string($conn, $name);

        $query = "UPDATE player SET name='$name', class_id=$classId WHERE id=$id";
        mysqli_query($conn, $query);

        header('Location: index.php?updated=1');
        exit;
    }
}

if ($_SERVER['REQUEST_METHOD'] === 'GET' && isset($_GET['action']) && $_GET['action'] === 'delete' && isset($_GET['id'])) {
    $id = intval($_GET['id']);
    if ($id > 0) {
        $query = "DELETE FROM player WHERE id=$id";
        mysqli_query($conn, $query);
    }
    header('Location: index.php?deleted=1');
    exit;
}

header('Location: index.php');
exit;



